{
	"name": "@noyzi/core",
	"version": "0.1.4",
	"description": "Seed-based deterministic gradient generator. Every seed maps to the same soft mesh gradient — forever.",
	"author": {
		"name": "breeg554",
		"url": "https://github.com/breeg554"
	},
	"license": "MIT",
	"homepage": "https://noyzi.dev/docs",
	"bugs": {
		"url": "https://github.com/breeg554/noyzi/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/breeg554/noyzi.git",
		"directory": "packages/core"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"gradient",
		"seed",
		"deterministic",
		"generative",
		"typescript",
		"css",
		"svg",
		"canvas",
		"webp",
		"png",
		"mesh-gradient"
	],
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"tsdown": "^0.15.6",
		"typescript": "^5.9.2"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
