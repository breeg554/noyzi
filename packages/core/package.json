{
	"name": "@noyzi/core",
	"version": "0.1.0",
	"description": "Seed-based deterministic gradient generator. Every seed maps to the same soft mesh gradient — forever.",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"gradient",
		"seed",
		"deterministic",
		"generative",
		"svg",
		"mesh-gradient"
	],
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"tsdown": "^0.15.6",
		"typescript": "^5.9.2"
	},
	"publishConfig": {
		"access": "public"
	}
}
