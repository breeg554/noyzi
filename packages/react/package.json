{
	"name": "@noyzi/react",
	"version": "0.1.0",
	"description": "React component for seed-based deterministic gradients. SSR-friendly, powered by @noyzi/core.",
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"gradient",
		"react",
		"avatar",
		"seed",
		"deterministic",
		"generative",
		"ssr"
	],
	"dependencies": {
		"@noyzi/core": "workspace:*",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.6.0"
	},
	"peerDependencies": {
		"react": ">=18",
		"tailwindcss": ">=4"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tsdown": "^0.15.6",
		"typescript": "^5.9.2"
	},
	"publishConfig": {
		"access": "public"
	}
}
