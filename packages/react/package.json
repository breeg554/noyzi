{
	"name": "@noyzi/react",
	"version": "0.1.5",
	"description": "React component for seed-based deterministic gradients. SSR-friendly, powered by @noyzi/core.",
	"author": {
		"name": "breeg554",
		"url": "https://github.com/breeg554"
	},
	"license": "MIT",
	"homepage": "https://noyzi.dev/docs#noyzigradient",
	"bugs": {
		"url": "https://github.com/breeg554/noyzi/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/breeg554/noyzi.git",
		"directory": "packages/react"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"gradient",
		"react",
		"component",
		"avatar",
		"seed",
		"deterministic",
		"generative",
		"ssr",
		"typescript",
		"tailwindcss",
		"structured-gradient"
	],
	"dependencies": {
		"@noyzi/core": "workspace:^",
		"clsx": "^2.1.1",
		"tailwind-merge": "^3.6.0"
	},
	"peerDependencies": {
		"react": ">=18",
		"tailwindcss": ">=4"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tsdown": "^0.15.6",
		"typescript": "^5.9.2"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
